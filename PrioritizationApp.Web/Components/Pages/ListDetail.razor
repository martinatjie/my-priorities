@page "/list/{ListId:guid}"
@rendermode InteractiveServer
@inject PriorityAppService AppService
@inject NavigationManager Navigation

<PageTitle>@(_list?.Name ?? "List")</PageTitle>

@if (_list is null)
{
    <p>List not found.</p>
    <a href="/">Back to lists</a>
}
else
{
    <div class="page-header">
        <div>
            <a href="/" class="back-link">← Lists</a>
            <h1 class="page-title">@_list.Name</h1>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="alert @(_messageIsWarning ? "alert-warning" : "alert-info")">@_message</div>
    }

    <section class="card-panel">
        <div class="form-row">
            <input class="form-control" @bind="_newItemText" @bind:event="oninput"
                   placeholder="Add an item" @onkeydown="AddOnEnter" />
            <button class="btn btn-primary" @onclick="AddItem" disabled="@string.IsNullOrWhiteSpace(_newItemText)">Add</button>
        </div>
        <p class="text-muted auto-hint">
            @(_data.Settings.AutoPrioritizeOnAdd
                ? "Auto-prioritize is ON — new items are placed into the ranking as you add them."
                : "Auto-prioritize is OFF — new items stay unprioritized until you run Prioritize.")
        </p>
    </section>

    @if (_showRerankConfirm)
    {
        <div class="card-panel warning-panel">
            <p>This list is already fully prioritized. Running Prioritize again will re-rank <strong>all</strong> items from scratch.</p>
            <div class="button-row">
                <button class="btn btn-danger" @onclick="ConfirmPrioritize">Continue</button>
                <button class="btn btn-secondary" @onclick="() => _showRerankConfirm = false">Cancel</button>
            </div>
        </div>
    }

    <section class="button-row">
        <button class="btn btn-primary btn-lg" @onclick="StartPrioritize"
                disabled="@(_list.Items.Count == 0)"
                title="@PrioritizeTooltip">
            Prioritize
        </button>
    </section>

    <section class="card-panel">
        <h2>Ranking</h2>
        @if (_ranked.Count == 0 && _unprioritized.Count == 0)
        {
            <p class="text-muted">No items yet. Add one above to get started.</p>
        }
        else
        {
            @if (_ranked.Count == 0)
            {
                <p class="text-muted">Nothing ranked yet — add items or run Prioritize.</p>
            }
            else
            {
                <ol class="ranked-list">
                    @foreach (var item in _ranked)
                    {
                        <li>
                            <span class="item-text">@item.Text</span>
                            <span class="item-actions">
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => BeginEdit(item)">Edit</button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteItem(item.Id)">Delete</button>
                            </span>
                        </li>
                    }
                </ol>
            }

            @if (_unprioritized.Count > 0)
            {
                <h3 class="unprioritized-heading">Not yet prioritized</h3>
                <p class="text-muted">Run Prioritize to place these into the ranking.</p>
                <ul class="item-list">
                    @foreach (var item in _unprioritized)
                    {
                        <li>
                            <span class="item-text">@item.Text</span>
                            <span class="item-actions">
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => BeginEdit(item)">Edit</button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteItem(item.Id)">Delete</button>
                            </span>
                        </li>
                    }
                </ul>
            }
        }
    </section>

    @if (_editingItemId is Guid editId)
    {
        <section class="card-panel">
            <h2>Edit item</h2>
            <div class="form-row">
                <input class="form-control" @bind="_editText" @bind:event="oninput" />
                <button class="btn btn-primary" @onclick="SaveEdit" disabled="@string.IsNullOrWhiteSpace(_editText)">Save</button>
                <button class="btn btn-secondary" @onclick="CancelEdit">Cancel</button>
            </div>
        </section>
    }
}

@code {
    [Parameter] public Guid ListId { get; set; }

    private const string PrioritizeTooltip =
        "Two scenarios: (1) If some items aren't ranked yet, Prioritize places just those into the existing ranking. " +
        "(2) If every item is already ranked, Prioritize asks you to confirm, then re-ranks the whole list from scratch.";

    private AppData _data = new();
    private PriorityList? _list;
    private IReadOnlyList<Item> _ranked = [];
    private IReadOnlyList<Item> _unprioritized = [];
    private string _newItemText = "";
    private string? _message;
    private bool _messageIsWarning;
    private bool _showRerankConfirm;
    private Guid? _editingItemId;
    private string _editText = "";

    protected override void OnInitialized() => Reload();

    protected override void OnParametersSet() => Reload();

    private void Reload()
    {
        _data = AppService.Load();
        _list = AppService.GetList(_data, ListId);
        RefreshViews();
    }

    private void RefreshViews()
    {
        if (_list is null)
        {
            _ranked = [];
            _unprioritized = [];
            return;
        }

        _ranked = RankingHelper.GetRankedItems(_list);
        _unprioritized = RankingHelper.GetUnprioritizedItems(_list);
    }

    private async Task AddOnEnter(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await AddItem();
    }

    private async Task AddItem()
    {
        if (_list is null || string.IsNullOrWhiteSpace(_newItemText))
            return;

        await AppService.AddItemAsync(_data, _list, _newItemText);
        _newItemText = "";
        _message = "Item added.";
        _messageIsWarning = false;
        Reload();
    }

    private void BeginEdit(Item item)
    {
        _editingItemId = item.Id;
        _editText = item.Text;
    }

    private void SaveEdit()
    {
        if (_list is null || _editingItemId is null || string.IsNullOrWhiteSpace(_editText))
            return;

        AppService.UpdateItem(_data, _list, _editingItemId.Value, _editText);
        _editingItemId = null;
        _message = "Item updated.";
        _messageIsWarning = false;
        Reload();
    }

    private void CancelEdit()
    {
        _editingItemId = null;
        _editText = "";
    }

    private void DeleteItem(Guid itemId)
    {
        if (_list is null)
            return;

        AppService.DeleteItem(_data, _list, itemId);
        _message = "Item deleted.";
        _messageIsWarning = false;
        Reload();
    }

    private void StartPrioritize()
    {
        if (_list is null)
            return;

        if (RankingHelper.IsFullyPrioritized(_list))
        {
            _showRerankConfirm = true;
            return;
        }

        _ = RunPrioritizeAsync(false);
    }

    private void ConfirmPrioritize() => _ = RunPrioritizeAsync(true);

    private async Task RunPrioritizeAsync(bool confirmFullRerank)
    {
        if (_list is null)
            return;

        _showRerankConfirm = false;
        var result = await AppService.PrioritizeAsync(_data, _list, confirmFullRerank);
        if (result is null)
        {
            _showRerankConfirm = false;
            return;
        }

        _message = result;
        _messageIsWarning = result.Contains("cancelled", StringComparison.OrdinalIgnoreCase);
        Reload();
    }
}
